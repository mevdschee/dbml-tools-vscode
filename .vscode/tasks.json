{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "reveal": "silent" }
    },
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^.+$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "\\[watch\\] build finished"
        }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    }
  ]
}
